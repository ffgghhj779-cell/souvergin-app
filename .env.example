# Sovereign Maareg — Environment Variables

# Copy this file to `.env` and fill in the real values.
# `.env` is listed in `.gitignore` and must NEVER be committed.

# ── Supabase ──────────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── How to use in development ────────────────────────────────────────────────
# flutter run \
#   --dart-define=SUPABASE_URL=$SUPABASE_URL \
#   --dart-define=SUPABASE_ANON_KEY=$SUPABASE_ANON_KEY

# ── How to use in VS Code ────────────────────────────────────────────────────
# Add to .vscode/launch.json under "toolArgs":
# "--dart-define=SUPABASE_URL=...", "--dart-define=SUPABASE_ANON_KEY=..."

# ── How to use in CI/CD (Codemagic / GitHub Actions) ───────────────────────
# Store values as encrypted secrets and pass them as --dart-define arguments
# during the build step. Never print them in logs.
