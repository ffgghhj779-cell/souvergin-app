<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Internet permission for Supabase + image loading -->
    <uses-permission android:name="android.permission.INTERNET"/>
    <!-- Vibration for haptic feedback -->
    <uses-permission android:name="android.permission.VIBRATE"/>

    <application
        android:label="Sovereign Maareg"
        android:name="${applicationName}"
        android:icon="@mipmap/launcher_icon"
        android:enableOnBackInvokedCallback="true"
        android:hardwareAccelerated="true"
        android:allowBackup="false"
        android:fullBackupContent="false">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:taskAffinity=""
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize">

            <!-- Specifies an Android theme to apply to this Activity -->
            <meta-data
                android:name="io.flutter.embedding.android.NormalTheme"
                android:resource="@style/NormalTheme"/>

            <!-- Enable Impeller: eliminates shader compilation jank -->
            <meta-data
                android:name="io.flutter.embedding.android.EnableImpeller"
                android:value="true"/>

            <!-- Request highest available refresh rate (120Hz on supported devices) -->
            <meta-data
                android:name="io.flutter.embedding.android.RequestedDisplayModeId"
                android:value="3"/>

            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>

        <!-- Don't delete the meta-data below -->
        <meta-data
            android:name="flutterEmbedding"
            android:value="2"/>
    </application>

    <!-- Required for flutter_local_notifications on Android 12 -->
    <queries>
        <intent>
            <action android:name="android.intent.action.PROCESS_TEXT"/>
            <data android:mimeType="text/plain"/>
        </intent>
    </queries>
</manifest>
